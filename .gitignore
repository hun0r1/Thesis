# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
.env
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# IDE files
.idea/
.vscode/
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# Raw data — large image files should not be committed
vehicle-damage-ai/data/raw/
vehicle-damage-ai/data/test/

# Cache files — API responses (can be large, re-generate as needed)
# Uncomment to exclude from version control:
# vehicle-damage-ai/cache/

# Generated outputs — large and reproducible
# Uncomment to exclude from version control:
# vehicle-damage-ai/outputs/
# vehicle-damage-ai/scores/
# vehicle-damage-ai/graphs/

# Secrets (NEVER commit these)
.env
*.env
secrets.json
